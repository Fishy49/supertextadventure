<div id="table-join-element-<%= game_number %>" data-game-id="<%= game.uuid %>" data-is-owner="<%= game.host?(current_user) %>">
  <div class="title"><strong>#<%= game_number %></strong> <%= game.name %></div>
  <% if game.description %>
    <div class="description">&gt; <em><%= game.description %></em></div>
  <% end %>
</div>
