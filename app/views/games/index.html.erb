<div class="text-center">
  <%= ascii("tavern") %>
  <h2 class="text-xl font-bold mt-2 mb-0">Ye Olde Tavern</h2>
  <p class="text-sm opacity-80 mb-4">You see many tables. Some contain adventurers. Others sit empty.</p>
</div>

<%= render(NoticeComponent.new(message: notice)) %>

<div class="text-center mb-6">
  <%= link_to "Start a New Game", new_game_path, class: "button px-6 py-2 text-lg" %>
</div>

<% all_games = [] %>
<% @hosted_games.each { |g| all_games << [g, :hosting] } %>
<% @joined_games.each { |g| all_games << [g, :playing] } %>
<% @joinable_games.each { |g| all_games << [g, :open] } %>

<% if all_games.any? %>
  <div class="space-y-3">
    <% all_games.each do |game, status| %>
      <%= render "games/tavern_game_card", game: game, status: status %>
    <% end %>
  </div>
<% else %>
  <p class="text-center opacity-80 mt-6">** No tables yet. Start a new game! **</p>
<% end %>
