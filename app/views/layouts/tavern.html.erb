<!DOCTYPE html>
<html class="w-[100%] h-[100%]">
  <head>
    <title>Super Text Adventure</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=VT323&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script data-site="NTUSEIK" src="https://analytics.richardcagle.dev/script.js" defer></script>
  </head>

  <body class="text-base bg-stone-800 text-terminal-green h-screen flex flex-col overflow-hidden pb-12 md:pb-0">

    <header class="p-3 border-b-2 border-b-terminal-green flex flex-wrap items-center justify-between gap-2">
      <h1 class="text-lg md:text-xl font-bold">
        <%= link_to "SuperTextAdventure_v0.1", tavern_path %>
      </h1>
      <% if logged_in? %>
        <span class="text-sm"><%= greeting %>, <%= current_user.username %></span>
      <% end %>
    </header>

    <main class="flex-1 overflow-y-auto terminal-scrollbars p-4 pb-16 md:pb-4">
      <div class="max-w-2xl mx-auto">
        <%= yield %>
      </div>
    </main>

    <footer class="p-3 border-t-2 border-t-terminal-green grid grid-cols-3 hidden md:grid">
      <%= render "footer" %>
    </footer>

    <%= render "mobile_nav", show_sidebar_toggle: false %>

  </body>
</html>
