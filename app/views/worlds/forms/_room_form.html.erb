<div class="space-y-4">
  <div>
    <label class="block mb-1 text-sm font-bold">Name *</label>
    <%= text_field_tag :name, entity_data["name"],
        required: true,
        class: "w-full bg-stone-900 border border-terminal-green p-2 text-terminal-green focus:outline-none" %>
  </div>

  <div>
    <label class="block mb-1 text-sm font-bold">Description *</label>
    <%= text_area_tag :description, entity_data["description"],
        rows: 3,
        required: true,
        class: "w-full bg-stone-900 border border-terminal-green p-2 text-terminal-green focus:outline-none" %>
  </div>

  <div>
    <label class="block mb-2 text-sm font-bold">Exits</label>
    <div id="exits-container" class="space-y-2">
      <% exits = entity_data["exits"] || {} %>
      <% if exits.any? %>
        <% exits.each do |direction, room| %>
          <div class="flex gap-2">
            <%= text_field_tag "exit_directions[]", direction,
                placeholder: "Direction (e.g., north)",
                class: "w-1/3 bg-stone-900 border border-terminal-green p-2 text-terminal-green focus:outline-none" %>
            <%= text_field_tag "exit_rooms[]", room,
                placeholder: "Room ID",
                class: "flex-1 bg-stone-900 border border-terminal-green p-2 text-terminal-green focus:outline-none" %>
          </div>
        <% end %>
      <% else %>
        <div class="flex gap-2">
          <%= text_field_tag "exit_directions[]", "",
              placeholder: "Direction (e.g., north)",
              class: "w-1/3 bg-stone-900 border border-terminal-green p-2 text-terminal-green focus:outline-none" %>
          <%= text_field_tag "exit_rooms[]", "",
              placeholder: "Room ID",
              class: "flex-1 bg-stone-900 border border-terminal-green p-2 text-terminal-green focus:outline-none" %>
        </div>
      <% end %>
    </div>
    <button type="button" onclick="this.previousElementSibling.insertAdjacentHTML('beforeend', this.previousElementSibling.lastElementChild.outerHTML)"
      class="mt-2 text-xs border border-terminal-green px-2 py-1 hover:bg-terminal-green hover:text-stone-800">
      + Add Exit
    </button>
  </div>

  <div>
    <label class="block mb-1 text-sm font-bold">Items (comma-separated IDs)</label>
    <%= text_field_tag :items, (entity_data["items"] || []).join(", "),
        placeholder: "book, sword, torch",
        class: "w-full bg-stone-900 border border-terminal-green p-2 text-terminal-green focus:outline-none" %>
  </div>

  <div>
    <label class="block mb-1 text-sm font-bold">NPCs (comma-separated IDs)</label>
    <%= text_field_tag :npcs, (entity_data["npcs"] || []).join(", "),
        placeholder: "ghost, guardian",
        class: "w-full bg-stone-900 border border-terminal-green p-2 text-terminal-green focus:outline-none" %>
  </div>
</div>
