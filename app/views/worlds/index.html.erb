<div class="max-w-6xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl">World Editor</h1>
    <%= link_to "Create New World", new_world_path, class: "px-4 py-2 border-2 border-terminal-green hover:bg-terminal-green hover:text-stone-800 transition-colors" %>
  </div>

  <% if @worlds.any? %>
    <div class="space-y-4">
      <% @worlds.each do |world| %>
        <div class="border-2 border-terminal-green p-4 hover:bg-stone-700 transition-colors">
          <div class="flex justify-between items-start">
            <div class="flex-1">
              <h2 class="text-xl mb-2"><%= world.name %></h2>
              <p class="text-sm opacity-80 mb-2"><%= world.description %></p>
              <div class="text-xs opacity-60">
                <span>Rooms: <%= world.rooms.count %></span> |
                <span>Items: <%= world.items.count %></span> |
                <span>NPCs: <%= world.npcs.count %></span> |
                <span>Creatures: <%= world.creatures.count %></span>
              </div>
            </div>
            <div class="flex gap-2 ml-4">
              <%= link_to "Edit", edit_world_path(world), class: "px-3 py-1 border border-terminal-green hover:bg-terminal-green hover:text-stone-800 transition-colors" %>
              <%= button_to "Delete", world_path(world), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this world?" }, class: "px-3 py-1 border border-red-500 text-red-500 hover:bg-red-500 hover:text-white transition-colors" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="border-2 border-terminal-green border-dashed p-8 text-center opacity-60">
      <p>No worlds found. Create your first world to get started!</p>
    </div>
  <% end %>
</div>

<% content_for :sidebar do %>
  <div class="p-4">
    <h3 class="text-xl mb-4">World Editor</h3>
    <p class="text-sm opacity-80 mb-4">
      Create and manage world templates for your text adventure games.
    </p>
    <div class="text-xs opacity-60">
      <p class="mb-2"><strong>Features:</strong></p>
      <ul class="list-disc list-inside space-y-1">
        <li>Visual JSON editor</li>
        <li>Live preview</li>
        <li>Syntax validation</li>
        <li>Multiple worlds</li>
      </ul>
    </div>
  </div>
<% end %>
